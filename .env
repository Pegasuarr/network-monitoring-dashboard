# AETHER Network Monitor - Environment Variables Configuration

# Server Settings
PORT=8080

# PostgreSQL Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=network_monitor
DB_SSLMODE=disable

# Redis Cache Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security & JWT Tokens
JWT_SECRET=super_secret_jwt_key_for_network_dashboard
JWT_ACCESS_TTL=60      # in minutes
JWT_REFRESH_TTL=7      # in days
RATE_LIMIT_LIMIT=120   # requests per minute
